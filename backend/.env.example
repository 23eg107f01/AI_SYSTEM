# LLM
GROQ_API_KEY=your_groq_api_key

# Neon Database
DATABASE_URL=postgresql://user:password@hostname:port/dbname

# Redis (optional, set REDIS_ENABLED=false to disable)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ChromaDB (local path OR cloud credentials)
CHROMA_PATH=./chroma_db
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# JWT
JWT_SECRET=your_256_bit_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cost controls
MAX_TOKENS_PER_CALL=1000
DAILY_BUDGET_USD=20.00

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# SLA Thresholds
SLA_AMBER_MINUTES=5
SLA_RED_MINUTES=15

# LangSmith (LLM monitoring & tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-customer-support
LANGSMITH_TRACING=true
