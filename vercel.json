{
    "functions": {
        "**/*.py": {
            "excludeFiles": "{frontend/**,backend/venv/**,backend/requirements*,backend/Dockerfile,*.mp4}"
        }
    },
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend",
            "framework": "fastapi"
        }
    }
}
